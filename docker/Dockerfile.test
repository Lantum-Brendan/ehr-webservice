# Test Dockerfile
# Used with docker-compose.test.yml for isolated test environment

FROM node:22-alpine AS test

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies including dev deps
RUN npm ci

# Copy source
COPY . .

# Build the application
RUN npm run build

# Run tests (can be overridden in docker-compose.test.yml)
CMD ["npm", "run", "test:e2e"]
