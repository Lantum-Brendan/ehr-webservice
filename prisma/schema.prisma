// This is your Prisma schema file for EHR Webservice
// Add your data models here

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Example Patient model - extend based on your FHIR requirements
model Patient {
  id        String   @id @default(uuid())
  mrn       String   @unique
  firstName String
  lastName  String
  dateOfBirth DateTime
  gender    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  encounters Encounter[]
  clinicalNotes ClinicalNote[]
  billingRecords BillingRecord[]
  appointments Appointment[]
  invoices Invoice[]
  labOrders LabOrder[]
  diagnoses Diagnosis[]
  allergies Allergy[]
  medications Medication[]

  @@map("patients")
}

model Encounter {
  id           String   @id @default(uuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  encounterType String
  startTime    DateTime
  endTime      DateTime?
  status       String   @default("planned")
  createdAt    DateTime @default(now())

  @@map("encounters")
}

model ClinicalNote {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  noteText   String   @db.Text
  authorId   String
  createdAt  DateTime @default(now())

  @@map("clinical_notes")
}

model BillingRecord {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  amount     Float
  status     String   @default("pending")
  code       String?
  createdAt  DateTime @default(now())

  @@map("billing_records")
}

// ========================================
// Appointment Module Models
// ========================================

model Provider {
  id             String   @id @default(uuid())
  name           String
  specialization String?
  isActive       Boolean  @default(true)
  createdAt     DateTime @default(now())
  
  appointments  Appointment[]
  
  @@map("providers")
}

model Location {
  id          String   @id @default(uuid())
  name        String
  type        String   // "exam_room", "lab", "waiting"
  facilityId  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  appointments Appointment[]
  
  @@map("locations")
}

model AppointmentType {
  id                    String   @id @default(uuid())
  name                  String
  defaultDurationMinutes Int      @default(15)
  color                 String?
  isActive               Boolean  @default(true)
  createdAt             DateTime @default(now())
  
  appointments Appointment[]
  
  @@map("appointment_types")
}

model Appointment {
  id                 String   @id @default(uuid())
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id])
  providerId        String
  provider          Provider @relation(fields: [providerId], references: [id])
  locationId        String?
  location          Location? @relation(fields: [locationId], references: [id])
  appointmentTypeId String
  appointmentType   AppointmentType @relation(fields: [appointmentTypeId], references: [id])
  durationMinutes  Int
  scheduledStart   DateTime
  scheduledEnd    DateTime
  status          String   @default("SCHEDULED")
  reason          String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cancelledAt    DateTime?
  cancelledBy    String?
  cancelledReason String?
  
  @@map("appointments")
}

model ClinicSettings {
  id                      String   @id @default(uuid())
  cancellationCutoffHours   Int      @default(24)
  clinicName              String   @default("Default Clinic")
  appointmentBufferMinutes Int      @default(0)   // buffer time between appointments
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("clinic_settings")
}

// Add more models based on your FHIR requirements

// ========================================
// Lab Module Models
// ========================================

model LabOrder {
  id           String   @id @default(uuid())
  patientId    String
  patient     Patient  @relation(fields: [patientId], references: [id])
  encounterId String?
  clinicianId String
  status    String   @default("ORDERED")  // ORDERED, COLLECTED, IN_PROGRESS, COMPLETED, CANCELLED
  priority   String   @default("ROUTINE")  // STAT, ROUTINE, URGENT
  testType   String   // e.g., "CBC", "BMP", "UA"
  notes     String?
  orderedAt  DateTime @default(now())
  collectedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results   LabResult[]

  @@index([patientId])
  @@index([status])
  @@index([orderedAt])
  @@map("lab_orders")
}

model LabResult {
  id           String   @id @default(uuid())
  labOrderId   String
  labOrder     LabOrder  @relation(fields: [labOrderId], references: [id])
  testName    String
  value      String?
  unit       String?
  referenceRange String?
  flag       String?  // ABNORMAL, NORMAL, CRITICAL
  status     String   @default("PENDING")  // PENDING, PRELIMINARY, FINAL, CORRECTED
  performedAt DateTime?
  resultedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([labOrderId])
  @@map("lab_results")
}

// ========================================
// Clinical Domain Models
// ========================================

model Diagnosis {
  id          String   @id @default(uuid())
  patientId   String
  patient    Patient  @relation(fields: [patientId], references: [id])
  encounterId String?
  code       String   // ICD-10 code
  description String
  status     String   @default("ACTIVE") // ACTIVE, RESOLVED, INACTIVE
  onsetDate  DateTime?
  resolvedDate DateTime?
  recordedBy  String
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([patientId])
  @@index([code])
  @@map("diagnoses")
}

model Allergy {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  allergen   String
  type       String   // DRUG, FOOD, ENVIRONMENTAL
  severity   String   // MILD, MODERATE, SEVERE, LIFE_THREATENING
  reaction   String?
  status     String   @default("ACTIVE") // ACTIVE, INACTIVE, RESOLVED
  recordedBy String
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([patientId])
  @@map("allergies")
}

model Medication {
  id           String   @id @default(uuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  encounterId  String?
  name         String
  dosage       String
  frequency   String
  route        String   // ORAL, IV, IM, TOPICAL, etc.
  startDate    DateTime
  endDate      DateTime?
  status       String   @default("ACTIVE") // ACTIVE, DISCONTINUED, ON_HOLD
  prescribedBy String
  prescribedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId])
  @@map("medications")
}
