// This is your Prisma schema file for EHR Webservice
// Add your data models here

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Example Patient model - extend based on your FHIR requirements
model Patient {
  id        String   @id @default(uuid())
  mrn       String   @unique
  firstName String
  lastName  String
  dateOfBirth DateTime
  gender    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  encounters Encounter[]
  clinicalNotes ClinicalNote[]
  billingRecords BillingRecord[]
  appointments Appointment[]
  invoices Invoice[]

  @@map("patients")
}

model Encounter {
  id             String   @id @default(uuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  providerId     String?
  provider       Provider? @relation(fields: [providerId], references: [id])
  encounterType  String
  startTime      DateTime
  endTime        DateTime?
  status         String   @default("planned")
  createdAt      DateTime @default(now())

  clinicalNotes  ClinicalNote[]
  invoices      Invoice[]

  @@map("encounters")
}

model ClinicalNote {
  id           String   @id @default(uuid())
  encounterId  String
  encounter   Encounter @relation(fields: [encounterId], references: [id])
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id])
  authorId     String
  subjective   String?   @db.Text
  objective   String?   @db.Text
  assessment   String?   @db.Text
  plan         String?   @db.Text
  status      String    @default("DRAFT")  // DRAFT, SIGNED
  signedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("clinical_notes")
}

model BillingRecord {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  amount     Float
  status     String   @default("pending")
  code       String?
  createdAt  DateTime @default(now())

  @@map("billing_records")
}

model Invoice {
  id           String   @id @default(uuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  encounterId  String?
  encounter    Encounter? @relation(fields: [encounterId], references: [id])
  status       String   @default("DRAFT")
  subtotal    Decimal  @default(0) @db.Decimal(12, 2)
  tax         Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @default(0) @db.Decimal(12, 2)
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lineItems   InvoiceLineItem[]
  payments   Payment[]

  @@map("invoices")
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  cptCode     String?
  quantity    Int       @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())

  @@map("invoice_line_items")
}

model Payment {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  amount      Decimal  @db.Decimal(12, 2)
  method     String
  reference   String?
  status     String   @default("PENDING")
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("payments")
}

// ========================================
// Appointment Module Models
// ========================================

model Provider {
  id             String   @id @default(uuid())
  name           String
  specialization String?
  isActive       Boolean  @default(true)
  selfBookingEnabled Boolean @default(false)  // patients can book this provider
  createdAt     DateTime @default(now())
  
  appointments  Appointment[]
  encounters    Encounter[]
  schedules     ProviderSchedule[]
  scheduleBlocks ScheduleBlock[]
  
  @@map("providers")
}

model Location {
  id          String   @id @default(uuid())
  name        String
  type        String   // "exam_room", "lab", "waiting"
  facilityId  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  appointments Appointment[]
  
  @@map("locations")
}

model AppointmentType {
  id                    String   @id @default(uuid())
  name                  String
  defaultDurationMinutes Int      @default(15)
  color                 String?
  isActive               Boolean  @default(true)
  selfBookingEnabled    Boolean  @default(false)  // patients can self-book this type
  createdAt             DateTime @default(now())
  
  appointments Appointment[]
  
  @@map("appointment_types")
}

// Provider recurring weekly schedule
model ProviderSchedule {
  id          String   @id @default(uuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  dayOfWeek  Int      // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime  String   // "08:00" in HH:mm format
  endTime   String   // "17:00" in HH:mm format
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  @@map("provider_schedules")
}

// One-off schedule blocks (lunch, vacation, meetings)
model ScheduleBlock {
  id           String   @id @default(uuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  startDateTime DateTime
  endDateTime DateTime
  reason      String   // "Lunch", "Annual Leave", "Meeting"
  createdAt   DateTime @default(now())
  
  @@map("schedule_blocks")
}

model Appointment {
  id                 String   @id @default(uuid())
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id])
  providerId        String
  provider          Provider @relation(fields: [providerId], references: [id])
  locationId        String?
  location          Location? @relation(fields: [locationId], references: [id])
  appointmentTypeId String
  appointmentType   AppointmentType @relation(fields: [appointmentTypeId], references: [id])
  durationMinutes  Int
  scheduledStart   DateTime
  scheduledEnd    DateTime
  status          String   @default("SCHEDULED")
  reason          String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cancelledAt    DateTime?
  cancelledBy    String?
  cancelledReason String?
  
  encounters    Encounter[]
  
  @@map("appointments")
}

model ClinicSettings {
  id                      String   @id @default(uuid())
  cancellationCutoffHours   Int      @default(24)
  clinicName              String   @default("Default Clinic")
  appointmentBufferMinutes Int      @default(0)   // buffer time between appointments
  patientSelfBookingEnabled Boolean  @default(false)  // allow patients to book
  maxAdvanceBookingDays    Int      @default(30)    // how far in advance patients can book
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("clinic_settings")
}

